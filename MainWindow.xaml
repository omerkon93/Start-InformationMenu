<Window x:Class="AdminInfoTools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{StaticResource StrWindowTitle}" Height="650" Width="1050" WindowStartupLocation="CenterScreen"
        Icon="app_icon.ico">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/> 
            <ColumnDefinition Width="*"/>   
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>    
            <RowDefinition Height="30"/>   
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Grid.Row="0" Background="#2D2D30">
            <StackPanel Margin="10">
                <TextBlock Text="{StaticResource StrMainMenu}" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,10,0,20" HorizontalAlignment="Center"/>
                
                <Button x:Name="BtnComputerMenu" Content="{StaticResource StrMenuComputer}" Height="40" Margin="0,5" Background="#3E3E42" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="BtnUserMenu" Content="{StaticResource StrMenuUser}" Height="40" Margin="0,5" Background="#3E3E42" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="BtnOptionsMenu" Content="{StaticResource StrMenuOptions}" Height="40" Margin="0,5" Background="#3E3E42" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Grid.Row="0" Margin="15">
            
            <Grid x:Name="ViewComputerManagement" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/> 
                    <ColumnDefinition Width="*"/>   
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    
                    <Grid Margin="0,0,0,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="{StaticResource StrCompTargetHostnames}" FontWeight="Bold" VerticalAlignment="Center"/>
                        
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0">
                            <ComboBox x:Name="CmbLoadOu" MinWidth="120" Margin="0,0,5,0" DisplayMemberPath="Key" SelectedValuePath="Value" ToolTip="{StaticResource StrCompLoadOuToolTip}"/>
                            <Button x:Name="BtnLoadFromOu" Content="{StaticResource StrCompBtnGet}" Margin="0,0,5,0" Padding="15,2" Cursor="Hand" Click="BtnLoadFromOu_Click"/>
                            <Button x:Name="BtnAdLoadHosts" Content="{StaticResource StrBtnIconLoad}" Margin="0,0,5,0" Padding="5,2" Cursor="Hand" ToolTip="{StaticResource StrToolTipLoadTxt}"/>
                            <Button x:Name="BtnAdSaveHosts" Content="{StaticResource StrBtnIconSave}" Margin="0,0,0,0" Padding="5,2" Cursor="Hand" ToolTip="{StaticResource StrToolTipSaveTxt}"/>
                        </StackPanel>
                    </Grid>
                    
                    <TextBox x:Name="TxtComputerObjectList" Height="90" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                    <Expander x:Name="ExpanderQuery" Header="{StaticResource StrCompExpQuery}" FontWeight="Bold" IsExpanded="True" Expanded="Accordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <Button x:Name="BtnGetInfo" Content="{StaticResource StrCompBtnGetSysInfo}" Height="25" Margin="0,0,0,5" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            <Button x:Name="BtnGetAdInfo" Content="{StaticResource StrCompBtnGetAdInfo}" Height="25" Margin="0,0,0,5" Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            <Button x:Name="BtnExport" Content="{StaticResource StrCompBtnExportCsv}" Height="25" Margin="0,0,0,10"/>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="ExpanderCreate" Header="{StaticResource StrCompExpCreate}" FontWeight="Bold" Expanded="Accordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            
                            <TextBlock Text="{StaticResource StrCompLblType}" Margin="0,0,0,2"/>
                            <ComboBox x:Name="CmbComputerType" Margin="0,0,0,10" DisplayMemberPath="Key" SelectedValuePath="Key"/>

                            <TextBlock Text="{StaticResource StrCompLblCreationMode}" FontWeight="Bold" Margin="0,0,0,2"/>
                            <RadioButton x:Name="RdoCreateFromList" Content="{StaticResource StrCompRdoFromList}" IsChecked="True" Margin="0,0,0,5" Checked="RdoCreateMode_Changed"/>
                            <RadioButton x:Name="RdoPatternCreate" Content="{StaticResource StrCompRdoBulk}" Margin="0,0,0,10" Checked="RdoCreateMode_Changed"/>

                            <StackPanel x:Name="PanelSequentialInput" Visibility="Collapsed" Margin="10,0,0,10">
                                <TextBlock Text="{StaticResource StrCompLblStartHost}" Margin="0,0,0,2"/>
                                <TextBox x:Name="TxtStartHostname" Height="25" Margin="0,0,0,5" VerticalContentAlignment="Center"/>
                                <TextBlock Text="{StaticResource StrCompLblNumCreate}" Margin="0,0,0,2"/>
                                <TextBox x:Name="TxtCreateCount" Height="25" Text="1" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <Button x:Name="BtnAdCreate" Content="{StaticResource StrCompBtnCreate}" Height="25" Margin="0,0,0,10" Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="ExpanderStatus" Header="{StaticResource StrCompExpStatus}" FontWeight="Bold" Expanded="Accordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnAdEnable" Content="{StaticResource StrBtnEnable}" Grid.Column="0" Height="25" Margin="0,0,5,0" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                <Button x:Name="BtnAdDisable" Content="{StaticResource StrBtnDisable}" Grid.Column="1" Height="25" Margin="5,0,0,0" Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="ExpanderManage" Header="{StaticResource StrCompExpManage}" FontWeight="Bold" Expanded="Accordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <TextBlock Text="{StaticResource StrCompLblTargetOu}" Margin="0,0,0,2"/>
                            <ComboBox x:Name="CmbTargetOu" Margin="0,0,0,5" DisplayMemberPath="Key" SelectedValuePath="Value"/>
                            <Button x:Name="BtnAdMove" Content="{StaticResource StrCompBtnMove}" Height="25" Margin="0,0,0,10" Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            
                            <TextBlock Text="{StaticResource StrCompLblDesc}" Margin="0,0,0,2"/>
                            <TextBox x:Name="TxtAdDescription" Height="25" Margin="0,0,0,5" Padding="2" VerticalContentAlignment="Center"/>
                            <Button x:Name="BtnAdSetDescription" Content="{StaticResource StrCompBtnSetDesc}" Height="25" Margin="0,0,0,10" Background="#6F42C1" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="ExpanderDelete" Header="{StaticResource StrExpDanger}" Foreground="Red" FontWeight="Bold" Expanded="Accordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <Button x:Name="BtnAdDelete" Content="{StaticResource StrCompBtnDelete}" Height="25" Background="#DC3545" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="ExpanderRemote" Header="{StaticResource StrCompExpRemote}" FontWeight="Bold" Expanded="Accordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <Button x:Name="BtnRunScript" Content="{StaticResource StrCompBtnRunScript}" Height="25" Margin="0,0,0,5" Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            <TextBlock Text="{StaticResource StrCompLblAdHoc}" Margin="0,5,0,2"/>
                            <TextBox x:Name="TxtCommand" Height="25" Margin="0,0,0,5" Padding="2" VerticalContentAlignment="Center" Text="{StaticResource StrCompTxtIpconfig}"/>
                            <Button x:Name="BtnRunCommand" Content="{StaticResource StrCompBtnRunCmd}" Height="25" Margin="0,0,0,10" Background="#6F42C1" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </Expander>
                </StackPanel>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="120"/>
                    </Grid.RowDefinitions>
                    
                    <DataGrid x:Name="MainDataGrid" Grid.Row="0" AutoGenerateColumns="True" IsReadOnly="True" AlternatingRowBackground="#F0F0F0" HeadersVisibility="Column" Margin="0,0,0,10"/>
                    
                    <GroupBox Grid.Row="1" Header="{StaticResource StrCompLogHeader}">
                        <ListBox x:Name="ListAdLogs" Background="#1E1E1E" Foreground="#00FF00" FontFamily="Consolas" Margin="5"/>
                    </GroupBox>
                </Grid>
            </Grid>

            <Grid x:Name="ViewUserManagement" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <Grid Margin="0,0,0,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{StaticResource StrUserTargetUsers}" FontWeight="Bold" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0">
                            <Button x:Name="BtnUserLoadHosts" Content="{StaticResource StrBtnLoadText}" Margin="0,0,5,0" Padding="15,2" Cursor="Hand"/>
                            <Button x:Name="BtnUserSaveHosts" Content="{StaticResource StrBtnSaveText}" Margin="0,0,0,0" Padding="15,2" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                    <TextBox x:Name="TxtUsernames" Text="{Binding TargetUsersText, UpdateSourceTrigger=PropertyChanged}" Height="90" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                    <Expander x:Name="ExpUserQuery" Header="{StaticResource StrUserExpQuery}" FontWeight="Bold" IsExpanded="True" Expanded="UserAccordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <Button x:Name="BtnGetUserAdInfo" Content="{StaticResource StrUserBtnQueryAd}" Command="{Binding GetUserInfoCommand}" Height="25" Margin="0,0,0,5" Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            <Button Command="{Binding ExportUsersCommand}" Content="{StaticResource StrUserBtnExportCsv}" Height="25" Margin="0,0,0,10"/>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="ExpUserStatus" Header="{StaticResource StrUserExpStatus}" FontWeight="Bold" Expanded="UserAccordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <Button Command="{Binding UnlockUserCommand}" Content="{StaticResource StrUserBtnUnlock}" Height="25" Margin="0,0,0,5" Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Command="{Binding EnableUserCommand}" Content="{StaticResource StrBtnEnable}" Grid.Column="0" Height="25" Margin="0,0,5,0" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                <Button Command="{Binding DisableUserCommand}" Content="{StaticResource StrBtnDisable}" Grid.Column="1" Height="25" Margin="5,0,0,0" Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="ExpUserOrg" Header="{StaticResource StrUserExpOrg}" FontWeight="Bold" Expanded="UserAccordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <TextBlock Text="{StaticResource StrUserLblDept}" Margin="0,0,0,2"/>
                            <TextBox x:Name="TxtUserDept" Height="25" Margin="0,0,0,5" Padding="2"/>
                            <TextBlock Text="{StaticResource StrUserLblTitle}" Margin="0,0,0,2"/>
                            <TextBox x:Name="TxtUserTitle" Height="25" Margin="0,0,0,5" Padding="2"/>
                            <Button x:Name="BtnUserSetOrg" Content="{StaticResource StrUserBtnSetOrg}" Height="25" Margin="0,0,0,10" Background="#6F42C1" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </Expander>
                    
                    <Expander x:Name="ExpUserSecurity" Header="{StaticResource StrUserExpSecurity}" Foreground="Red" FontWeight="Bold" Expanded="UserAccordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <Button x:Name="BtnUserForcePassReset" Content="{StaticResource StrUserBtnForcePass}" Height="25" Background="#DC3545" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </Expander>
                </StackPanel>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="120"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="UserDataGrid" ItemsSource="{Binding UserResults}" Grid.Row="0" AutoGenerateColumns="True" IsReadOnly="True" AlternatingRowBackground="#F0F0F0" HeadersVisibility="Column" Margin="0,0,0,10"/>
                    <GroupBox Grid.Row="1" Header="{StaticResource StrUserLogHeader}">
                        <ListBox ItemsSource="{Binding UserLogs}" Background="#1E1E1E" Foreground="#00FF00" FontFamily="Consolas" Margin="5"/>
                    </GroupBox>
                </Grid>
            </Grid>

            <Grid x:Name="ViewOptions" Visibility="Collapsed">
                <TabControl Margin="5" Background="Transparent" BorderThickness="0">
                    
                    <TabItem Header="{StaticResource StrOptTabSession}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="15">
                                <TextBlock Text="{StaticResource StrOptLblSecurity}" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="{StaticResource StrOptDescSecurity}" TextWrapping="Wrap" Margin="0,0,0,20" Foreground="Gray"/>
                                
                                <TextBlock Text="{StaticResource StrOptLblDomainUser}" Margin="0,0,0,5" FontWeight="Bold"/>
                                <TextBox x:Name="TxtAdUsername" Height="30" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                                <TextBlock Text="{StaticResource StrOptLblPassword}" Margin="0,0,0,5" FontWeight="Bold"/>
                                <PasswordBox x:Name="TxtAdPassword" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center"/>
                                
                                <CheckBox x:Name="ChkSaveCredentials" Content="{StaticResource StrOptChkRemember}" Margin="0,0,0,20" HorizontalAlignment="Left"/>

                                <Button x:Name="BtnSaveCredentials" Content="{StaticResource StrOptBtnSetCreds}" Height="35" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                <TextBlock x:Name="LblCredStatus" Text="{StaticResource StrOptLblCredStatusDef}" Margin="0,15,0,0" Foreground="Orange" FontWeight="Bold"/>
                                
                                <Separator Margin="0,30,0,20"/>

                                <TextBlock Text="{StaticResource StrOptLblAppSet}" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="{StaticResource StrOptDescAppSet}" TextWrapping="Wrap" Margin="0,0,0,20" Foreground="Gray"/>

                                <TextBlock Text="{StaticResource StrOptLblConfigPath}" Margin="0,0,0,5" FontWeight="Bold"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtSettingsPath" Grid.Column="0" Height="30" VerticalContentAlignment="Center" Text="{StaticResource StrOptDefConfigPath}"/>
                                    <Button x:Name="BtnBrowseSettings" Grid.Column="1" Content="{StaticResource StrOptBtnBrowse}" Height="30" Margin="5,0,0,0" Cursor="Hand" Padding="10,2"/>
                                </Grid>

                                <Button x:Name="BtnLoadSettingsOptions" Content="{StaticResource StrOptBtnLoadConfig}" Height="35" Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="{StaticResource StrOptTabEdit}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="15">
                                <TextBlock Text="{StaticResource StrOptLblEditJson}" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="{StaticResource StrOptDescEditJson}" TextWrapping="Wrap" Margin="0,0,0,20" Foreground="Gray"/>
                                
                                <GroupBox Header="{StaticResource StrOptGrpAd}" Margin="0,0,0,15" Padding="10" Foreground="Black" BorderBrush="#3E3E42">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Text="{StaticResource StrOptLblDomainName}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBox x:Name="TxtEditDomainName" Grid.Row="0" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>
                                        
                                        <TextBlock Text="{StaticResource StrOptLblTargetServer}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBox x:Name="TxtEditTargetServer" Grid.Row="1" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>

                                        <TextBlock Text="{StaticResource StrOptLblCompPattern}" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBox x:Name="TxtEditCompPattern" Grid.Row="2" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="{StaticResource StrOptGrpAppConf}" Margin="0,0,0,20" Padding="10" Foreground="Black" BorderBrush="#3E3E42">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Text="{StaticResource StrOptLblLogsDir}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBox x:Name="TxtEditLogsDir" Grid.Row="0" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>
                                        
                                        <TextBlock Text="{StaticResource StrOptLblRemTemp}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBox x:Name="TxtEditRemoteTemp" Grid.Row="1" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>

                                        <TextBlock Text="{StaticResource StrOptLblDefComp}" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBox x:Name="TxtEditDefCompList" Grid.Row="2" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>

                                        <TextBlock Text="{StaticResource StrOptLblDefUser}" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBox x:Name="TxtEditDefUserList" Grid.Row="3" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>

                                        <TextBlock Text="{StaticResource StrOptLblPsExec}" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBox x:Name="TxtEditPsExec" Grid.Row="4" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>

                                        <TextBlock Text="{StaticResource StrOptLblDameware}" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                                        <TextBox x:Name="TxtEditDameware" Grid.Row="5" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>
                                    </Grid>
                                </GroupBox>
                                <Button x:Name="BtnSaveConfigToDisk" Content="{StaticResource StrOptBtnSaveConfig}" Height="35" Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    
                </TabControl>
            </Grid>
        </Grid>

        <StatusBar Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Background="#007ACC" Foreground="White">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>