<Window x:Class="AdminInfoTools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Info Tools" Height="650" Width="1050" WindowStartupLocation="CenterScreen"
        Icon="app_icon.ico">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/> 
            <ColumnDefinition Width="*"/>   
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>    
            <RowDefinition Height="30"/>   
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Grid.Row="0" Background="#2D2D30">
            <StackPanel Margin="10">
                <TextBlock Text="MAIN MENU" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,10,0,20" HorizontalAlignment="Center"/>
                
                <Button x:Name="BtnComputerMenu" Content="💻 Computer Management" Height="40" Margin="0,5" Background="#3E3E42" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="BtnUserMenu" Content="👤 User Management" Height="40" Margin="0,5" Background="#3E3E42" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="BtnOptionsMenu" Content="🔑 Credentials &amp; Options" Height="40" Margin="0,5" Background="#3E3E42" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Grid.Row="0" Margin="15">
            
            <Grid x:Name="ViewComputerManagement" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/> 
                    <ColumnDefinition Width="*"/>   
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Text="Target Hostnames:" FontWeight="Bold" VerticalAlignment="Center"/>
                        
                        <ComboBox x:Name="CmbLoadOu" Grid.Column="1" Width="80" Margin="5,0,0,0" DisplayMemberPath="Key" SelectedValuePath="Value" ToolTip="Select an OU from Settings"/>
                        <Button x:Name="BtnLoadFromOu" Content="🏢 Get" Grid.Column="2" Width="40" Margin="5,0,0,0" Padding="2" Cursor="Hand" Click="BtnLoadFromOu_Click"/>
                        
                        <Button x:Name="BtnAdLoadHosts" Content="📂" Grid.Column="3" Width="30" Margin="5,0,0,0" Padding="2" Cursor="Hand" ToolTip="Load from Text File"/>
                        <Button x:Name="BtnAdSaveHosts" Content="💾" Grid.Column="4" Width="30" Margin="5,0,0,0" Padding="2" Cursor="Hand" ToolTip="Save to Text File"/>
                    </Grid>
                    
                    <TextBox x:Name="TxtAdHostnames" Height="90" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                    <Expander x:Name="ExpanderQuery" Header="1. Query Computers" FontWeight="Bold" IsExpanded="True" Expanded="Accordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <Button x:Name="BtnGetInfo" Content="🔍 Get System Info (WMI)" Height="25" Margin="0,0,0,5" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            <Button x:Name="BtnGetAdInfo" Content="🌐 Get AD Info" Height="25" Margin="0,0,0,5" Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            <Button x:Name="BtnExport" Content="📊 Export Results to CSV" Height="25" Margin="0,0,0,10"/>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="ExpanderCreate" Header="2. Create Computer" FontWeight="Bold" Expanded="Accordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            
                            <TextBlock Text="Computer Type:" Margin="0,0,0,2"/>
                            <ComboBox x:Name="CmbComputerType" Margin="0,0,0,10" DisplayMemberPath="Key" SelectedValuePath="Key"/>

                            <TextBlock Text="Creation Mode:" FontWeight="Bold" Margin="0,0,0,2"/>
                            <RadioButton x:Name="RdoCreateFromList" Content="From Target Hostnames List" IsChecked="True" Margin="0,0,0,5" Checked="RdoCreateMode_Changed"/>
                            <RadioButton x:Name="RdoCreateSequential" Content="Sequential (Serial Numbers)" Margin="0,0,0,10" Checked="RdoCreateMode_Changed"/>

                            <StackPanel x:Name="PanelSequentialInput" Visibility="Collapsed" Margin="10,0,0,10">
                                <TextBlock Text="Starting Hostname (e.g., AF-W-0001):" Margin="0,0,0,2"/>
                                <TextBox x:Name="TxtStartHostname" Height="25" Margin="0,0,0,5" VerticalContentAlignment="Center"/>
                                <TextBlock Text="Number of Objects to Create:" Margin="0,0,0,2"/>
                                <TextBox x:Name="TxtCreateCount" Height="25" Text="1" VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <Button x:Name="BtnAdCreate" Content="➕ Create Object(s)" Height="25" Margin="0,0,0,10" Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="ExpanderStatus" Header="3. Set Status" FontWeight="Bold" Expanded="Accordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button x:Name="BtnAdEnable" Content="✔️ Enable" Height="25" Width="125" Margin="0,0,10,0" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                <Button x:Name="BtnAdDisable" Content="❌ Disable" Height="25" Width="125" Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="ExpanderManage" Header="4. Manage Properties" FontWeight="Bold" Expanded="Accordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <TextBlock Text="Target OU:" Margin="0,0,0,2"/>
                            <ComboBox x:Name="CmbTargetOu" Margin="0,0,0,5" DisplayMemberPath="Key" SelectedValuePath="Value"/>
                            <Button x:Name="BtnAdMove" Content="➡️ Move Object(s)" Height="25" Margin="0,0,0,10" Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            
                            <TextBlock Text="Description:" Margin="0,0,0,2"/>
                            <TextBox x:Name="TxtAdDescription" Height="25" Margin="0,0,0,5" Padding="2" VerticalContentAlignment="Center"/>
                            <Button x:Name="BtnAdSetDescription" Content="✏️ Set Description" Height="25" Margin="0,0,0,10" Background="#6F42C1" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="ExpanderDelete" Header="5. Danger Zone" Foreground="Red" FontWeight="Bold" Expanded="Accordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <Button x:Name="BtnAdDelete" Content="🗑️ Delete Object(s)" Height="25" Background="#DC3545" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="ExpanderRemote" Header="6. Remote Execution" FontWeight="Bold" Expanded="Accordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <Button x:Name="BtnRunScript" Content="📜 Run Remote Script" Height="25" Margin="0,0,0,5" Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            <TextBlock Text="Ad-Hoc Command:" Margin="0,5,0,2"/>
                            <TextBox x:Name="TxtCommand" Height="25" Margin="0,0,0,5" Padding="2" VerticalContentAlignment="Center" Text="ipconfig /flushdns"/>
                            <Button x:Name="BtnRunCommand" Content="⚡ Run Command" Height="25" Margin="0,0,0,10" Background="#6F42C1" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </Expander>
                </StackPanel>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="120"/>
                    </Grid.RowDefinitions>
                    
                    <DataGrid x:Name="MainDataGrid" Grid.Row="0" AutoGenerateColumns="True" IsReadOnly="True" AlternatingRowBackground="#F0F0F0" HeadersVisibility="Column" Margin="0,0,0,10"/>
                    
                    <GroupBox Grid.Row="1" Header="Active Directory Operations Log">
                        <ListBox x:Name="ListAdLogs" Background="#1E1E1E" Foreground="#00FF00" FontFamily="Consolas" Margin="5"/>
                    </GroupBox>
                </Grid>
            </Grid>

            <Grid x:Name="ViewUserManagement" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Target Users (SAM Account):" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button x:Name="BtnUserLoadHosts" Content="📂 Load" Grid.Column="1" Width="55" Margin="5,0,0,0" Padding="2" Cursor="Hand"/>
                        <Button x:Name="BtnUserSaveHosts" Content="💾 Save" Grid.Column="2" Width="55" Margin="5,0,0,0" Padding="2" Cursor="Hand"/>
                    </Grid>
                    <TextBox x:Name="TxtUsernames" Text="{Binding TargetUsersText, UpdateSourceTrigger=PropertyChanged}" Height="90" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                    <Expander x:Name="ExpUserQuery" Header="1. Query Users" FontWeight="Bold" IsExpanded="True" Expanded="UserAccordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <Button x:Name="BtnGetUserAdInfo" Content="🌐 Query AD Users" Command="{Binding GetUserInfoCommand}" Height="25" Margin="0,0,0,5" Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            <Button Command="{Binding ExportUsersCommand}" Content="📊 Export to CSV" Height="25" Margin="0,0,0,10"/>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="ExpUserStatus" Header="2. Account Status" FontWeight="Bold" Expanded="UserAccordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <Button Command="{Binding UnlockUserCommand}" Content="🔓 Unlock Account(s)" Height="25" Margin="0,0,0,5" Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Command="{Binding EnableUserCommand}" Content="✔️ Enable" Height="25" Width="125" Margin="0,0,10,0" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                <Button Command="{Binding DisableUserCommand}" Content="❌ Disable" Height="25" Width="125" Background="#6C757D" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="ExpUserOrg" Header="3. Organization" FontWeight="Bold" Expanded="UserAccordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <TextBlock Text="Department:" Margin="0,0,0,2"/>
                            <TextBox x:Name="TxtUserDept" Height="25" Margin="0,0,0,5" Padding="2"/>
                            <TextBlock Text="Job Title:" Margin="0,0,0,2"/>
                            <TextBox x:Name="TxtUserTitle" Height="25" Margin="0,0,0,5" Padding="2"/>
                            <Button x:Name="BtnUserSetOrg" Content="🏢 Set Organization Info" Height="25" Margin="0,0,0,10" Background="#6F42C1" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </Expander>
                    
                    <Expander x:Name="ExpUserSecurity" Header="4. Security Zone" Foreground="Red" FontWeight="Bold" Expanded="UserAccordion_Expanded" Margin="0,0,0,5">
                        <StackPanel Margin="0,5,0,0" TextElement.FontWeight="Normal">
                            <Button x:Name="BtnUserForcePassReset" Content="🔑 Force Password Reset (Next Logon)" Height="25" Background="#DC3545" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </Expander>
                </StackPanel>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="120"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="UserDataGrid" ItemsSource="{Binding UserResults}" Grid.Row="0" AutoGenerateColumns="True" IsReadOnly="True" AlternatingRowBackground="#F0F0F0" HeadersVisibility="Column" Margin="0,0,0,10"/>
                    <GroupBox Grid.Row="1" Header="User Operations Log">
                        <ListBox ItemsSource="{Binding UserLogs}" Background="#1E1E1E" Foreground="#00FF00" FontFamily="Consolas" Margin="5"/>
                    </GroupBox>
                </Grid>
            </Grid>

            <Grid x:Name="ViewOptions" Visibility="Collapsed">
                <TabControl Margin="5" Background="Transparent" BorderThickness="0">
                    
                    <TabItem Header="Session &amp; File">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="15">
                                <TextBlock Text="Security &amp; Credentials" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="Enter the Active Directory credentials to be used for operations during this session. You can optionally save them locally." TextWrapping="Wrap" Margin="0,0,0,20" Foreground="Gray"/>
                                
                                <TextBlock Text="Domain\Username:" Margin="0,0,0,5" FontWeight="Bold"/>
                                <TextBox x:Name="TxtAdUsername" Width="250" Height="30" HorizontalAlignment="Left" Margin="0,0,0,15" VerticalContentAlignment="Center"/>

                                <TextBlock Text="Password:" Margin="0,0,0,5" FontWeight="Bold"/>
                                <PasswordBox x:Name="TxtAdPassword" Width="250" Height="30" HorizontalAlignment="Left" Margin="0,0,0,10" VerticalContentAlignment="Center"/>
                                
                                <CheckBox x:Name="ChkSaveCredentials" Content="Remember Credentials (Saves locally)" Margin="0,0,0,20" HorizontalAlignment="Left"/>

                                <Button x:Name="BtnSaveCredentials" Content="💾 Set Session Credentials" Width="250" Height="35" HorizontalAlignment="Left" Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                <TextBlock x:Name="LblCredStatus" Text="Status: Credentials Not Set" Margin="0,15,0,0" Foreground="Orange" FontWeight="Bold"/>
                                
                                <Separator Margin="0,30,0,20" HorizontalAlignment="Left" Width="400"/>

                                <TextBlock Text="Application Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="Load the configuration file for Active Directory mapping and tool paths." TextWrapping="Wrap" Margin="0,0,0,20" Foreground="Gray"/>

                                <TextBlock Text="Configuration File Path:" Margin="0,0,0,5" FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBox x:Name="TxtSettingsPath" Width="360" Height="30" VerticalContentAlignment="Center" Text="C:\Projects\Start-InformationMenu\cs\Settings\settings.jsonc"/>
                                    <Button x:Name="BtnBrowseSettings" Content="..." Width="35" Height="30" Margin="5,0,0,0" Cursor="Hand"/>
                                </StackPanel>

                                <Button x:Name="BtnLoadSettingsOptions" Content="⚙️ Load Configuration" Width="250" Height="35" HorizontalAlignment="Left" Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Edit Configuration">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="15">
                                <TextBlock Text="Edit JSON Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="Modify the core settings. Changes will be serialized and saved back to the loaded configuration file." TextWrapping="Wrap" Margin="0,0,0,20" Foreground="Gray"/>
                                
                                <GroupBox Header="Active Directory" Margin="0,0,0,15" Padding="10" Foreground="Black" BorderBrush="#3E3E42">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="300"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Text="DomainName:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"/>
                                        <TextBox x:Name="TxtEditDomainName" Grid.Row="0" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>
                                        
                                        <TextBlock Text="TargetServer:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"/>
                                        <TextBox x:Name="TxtEditTargetServer" Grid.Row="1" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>

                                        <TextBlock Text="ComputerNamePattern:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"/>
                                        <TextBox x:Name="TxtEditCompPattern" Grid.Row="2" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="AppConfig &amp; ExternalTools" Margin="0,0,0,20" Padding="10" Foreground="Black" BorderBrush="#3E3E42">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="300"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Text="LogsDirectory:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"/>
                                        <TextBox x:Name="TxtEditLogsDir" Grid.Row="0" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>
                                        
                                        <TextBlock Text="RemoteTempPath:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"/>
                                        <TextBox x:Name="TxtEditRemoteTemp" Grid.Row="1" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>

                                        <TextBlock Text="DefaultComputerList:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"/>
                                        <TextBox x:Name="TxtEditDefCompList" Grid.Row="2" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>

                                        <TextBlock Text="DefaultUserList:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"/>
                                        <TextBox x:Name="TxtEditDefUserList" Grid.Row="3" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>

                                        <TextBlock Text="PsExecPath:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"/>
                                        <TextBox x:Name="TxtEditPsExec" Grid.Row="4" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>

                                        <TextBlock Text="DamewarePath:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" FontWeight="Bold"/>
                                        <TextBox x:Name="TxtEditDameware" Grid.Row="5" Grid.Column="1" Height="25" VerticalContentAlignment="Center"/>
                                    </Grid>
                                </GroupBox>
                                <Button x:Name="BtnSaveConfigToDisk" Content="💾 Save Settings to File" Width="200" Height="35" HorizontalAlignment="Left" Background="#17A2B8" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    
                </TabControl>
            </Grid>
        </Grid>

        <StatusBar Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Background="#007ACC" Foreground="White">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>